{
  "name": "next14-notion-starter",
  "version": "0.0.2",
  "private": true,
  "description": "NextJS14 website using Notion as CMS",
  "author": "Vivek Kaushik",
  "license": "MIT",
  "scripts": {
    "generate:project_heirarchy": "mkdir docs; echo \\`\\`\\`  > docs/Project_Structure.md; tree -L 3 -I node_modules >> docs/Project_Structure.md; dotenvx genexample",
    "dotenvx": "dotenvx",
    "dev": "dotenvx run -- next dev",
    "build": "dotenvx run -- next build",
    "start": "dotenvx run -- next start",
    "lint": "next lint",
    "deploy": "vercel deploy",
    "deps": "run-s deps:*",
    "deps:update": "[ -z $GITHUB_ACTIONS ] && yarn add notion-client notion-types notion-utils react-notion-x || echo 'Skipping deps:update on CI'",
    "deps:link": "[ -z $GITHUB_ACTIONS ] && yarn link notion-client notion-types notion-utils react-notion-x || echo 'Skipping deps:link on CI'",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "test": "run-p test:*",
    "test:lint": "eslint '**/*.{ts,tsx}'",
    "test:prettier": "prettier '**/*.{js,jsx,ts,tsx}' --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@fisch0920/use-dark-mode": "^2.4.0",
    "@react-icons/all-files": "^4.1.0",
    "@vercel/analytics": "^1.2.2",
    "@vercel/og": "^0.0.19",
    "@vercel/speed-insights": "^1.0.10",
    "classnames": "^2.3.1",
    "date-fns": "^2.28.0",
    "expiry-map": "^2.0.0",
    "got": "^12.0.3",
    "isomorphic-unfetch": "^3.1.0",
    "lodash.omit": "^4.5.0",
    "lqip-modern": "^2.0.0",
    "next": "^16.1.6",
    "notion-client": "^7.8.2",
    "notion-types": "^7.8.2",
    "notion-utils": "^7.8.2",
    "p-map": "^5.3.0",
    "p-memoize": "^6.0.2",
    "prismjs": "^1.29.0",
    "raf": "^3.4.1",
    "random": "^4.1.0",
    "react": "^19.2.4",
    "react-body-classname": "^1.3.1",
    "react-dom": "^19.2.4",
    "react-notion-x": "^7.8.2",
    "react-tweet-embed": "^2.0.0",
    "react-use": "^17.4.2",
    "rss": "^1.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "@dotenvx/dotenvx": "^1.52.0",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@next/bundle-analyzer": "^12.3.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/lodash.omit": "^4.5.9",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^7.0.2",
    "eslint": "^10.0.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.0.11",
    "npm-run-all": "^1.1.3",
    "prettier": "^2.7.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "cacheable-request": {
      "keyv": "npm:@keyvhq/core@~1.6.6"
    },
    "minimatch": "^10.2.2",
    "brace-expansion": "^2.0.1",
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
