{
  "name": "nextjs-notion-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Next.js website using Notion as CMS",
  "author": "Vivek Kaushik",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --apply .",
    "test": "npm run check"
  },
  "dependencies": {
    "@react-icons/all-files": "^4.1.0",
    "@vercel/analytics": "^1.2.2",
    "@vercel/og": "^0.0.19",
    "@vercel/speed-insights": "^1.0.10",
    "next": "^16.1.6",
    "notion-client": "^7.8.2",
    "notion-types": "^7.8.2",
    "notion-utils": "^7.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-notion-x": "^7.8.2",
    "react-tweet-embed": "^2.0.0",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "@next/bundle-analyzer": "^12.3.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "cacheable-request": {
      "keyv": "npm:@keyvhq/core@~1.6.6"
    },
    "minimatch": "^10.2.2",
    "brace-expansion": "^2.0.1",
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
